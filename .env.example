# Argus Environment Configuration
# Copy this file to .env and fill in your API keys

# Required: LLM API key (choose one provider)
# Anthropic (recommended)
ANTHROPIC_API_KEY=sk-ant-...

# Or OpenRouter (access to multiple models)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: Ollama for local testing
# OLLAMA_API_KEY=...

# Optional: Custom report output directory
# ARGUS_REPORT_DIR=~/security-reports
